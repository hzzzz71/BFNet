# 应用配置
APP_NAME=智能息肉诊疗辅助平台
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# CORS配置
ALLOWED_HOSTS=["http://localhost:3000", "http://127.0.0.1:3000"]

# 数据库配置
# 本地开发可使用 SQLite: sqlite+aiosqlite:///./polyp_ai.db
DATABASE_URL=postgresql://<username>:<password>@localhost:5432/polyp_ai_db

# Redis配置
REDIS_URL=redis://localhost:6379

# MinIO配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<minio-access-key>
MINIO_SECRET_KEY=<minio-secret-key>
MINIO_BUCKET=polyp-images
MINIO_SECURE=False

# BFNet模型配置
MODEL_PATH=../BFNet/model/BFNet.pth
MODEL_PVT_PATH=../BFNet/pvt_v2_b2.pth
MODEL_DEVICE=cuda
MODEL_IMAGE_SIZE=704

# LLM配置
OPENAI_API_KEY=<openai-api-key>
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4-turbo-preview
DEEPSEEK_API_KEY=<deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
SILICONFLOW_API_KEY=<siliconflow-api-key>
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
DEFAULT_LLM_MODEL_KEY=deepseek_chat
SILICONFLOW_KIMI_MODEL_ID=<kimi-model-id>
SILICONFLOW_GLM_MODEL_ID=<glm-model-id>
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SECONDS=300

# Supabase配置（未使用可留空）
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# 文件上传限制
MAX_FILE_SIZE=104857600
ALLOWED_IMAGE_EXTENSIONS=[".jpg", ".jpeg", ".png", ".tiff", ".bmp"]
ALLOWED_VIDEO_EXTENSIONS=[".mp4", ".avi", ".mov", ".wmv"]

# JWT配置
SECRET_KEY=<change-this-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
